{
  "name": "@astrake/lumora-server",
  "version": "0.1.3",
  "description": "Slim Bun + Hono framework — typed config, file-based resources, auto-generated REST/SSE/WebSocket endpoints, JWT auth, SQLite, and an interactive init wizard.",
  "author": "Anuvab Chakraborty (https://github.com/madlybong)",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "init": "./bin/init.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "keywords": [
    "bun",
    "hono",
    "framework",
    "rest",
    "api",
    "sse",
    "websocket",
    "sqlite",
    "typescript",
    "lumora",
    "astrake"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/madlybong/LumoraServer.git"
  },
  "homepage": "https://server.lumora.astrake.com",
  "bugs": {
    "url": "https://github.com/madlybong/LumoraServer/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/madlybong"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "src",
    "bin",
    "tsconfig.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts ./bin/init.ts --outdir ./dist",
    "check": "tsc -p ./tsconfig.json"
  },
  "dependencies": {
    "hono": "^4.9.7"
  }
}
