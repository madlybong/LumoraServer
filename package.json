{
  "name": "lumora-server-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo workspace for @astrake/lumora-server — Bun + Hono typed API framework.",
  "author": "Anuvab Chakraborty (https://github.com/madlybong)",
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "packages/core",
    "apps/starter"
  ],
  "scripts": {
    "build": "bun run ./tools/build.ts",
    "check": "bun run ./tools/check.ts",
    "dev": "bun run ./apps/starter/src/index.ts",
    "test": "bun test",
    "cli": "bun run ./packages/core/bin/init.ts",
    "version:sync": "bun run ./tools/version.ts",
    "version:check": "bun run ./tools/version.ts && git diff --exit-code",
    "changelog": "bun run ./tools/changelog.ts",
    "release:prep": "bun run ./tools/version.ts && bun run ./tools/changelog.ts"
  },
  "devDependencies": {
    "bun-types": "^1.3.12",
    "typescript": "^5.9.3"
  }
}
